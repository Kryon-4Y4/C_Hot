# ============================================
# 手机维修配件外贸数据管理系统 - 环境变量配置
# ============================================

# --------------------------------------------
# 数据库配置 (PostgreSQL)
# --------------------------------------------
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=phone_parts_db

# 完整数据库连接URL
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/phone_parts_db

# --------------------------------------------
# Redis配置
# --------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------
# 安全密钥 (重要: 生产环境必须修改!)
# 生成方式: openssl rand -hex 32
# --------------------------------------------
SECRET_KEY=your-super-secret-key-change-this-in-production

# --------------------------------------------
# 调试模式
# 生产环境必须设为 false
# --------------------------------------------
DEBUG=false

# --------------------------------------------
# 服务地址配置
# --------------------------------------------
API_GATEWAY_URL=http://api-gateway:8000
ADMIN_CONSOLE_URL=http://admin-console:5000
OPS_CENTER_URL=http://ops-center:8001

# --------------------------------------------
# 爬虫配置
# --------------------------------------------
CRAWLER_REQUEST_DELAY=2
CRAWLER_MAX_RETRIES=3

# --------------------------------------------
# 邮件配置 (可选,用于告警通知)
# --------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alert@example.com
# SMTP_PASSWORD=your_smtp_password
